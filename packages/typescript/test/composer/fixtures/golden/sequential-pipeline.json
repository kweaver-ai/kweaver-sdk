{
  "id": "sequential-pipeline",
  "prompt": "Code development with architect, developer, and reviewer",
  "agents": ["architect", "developer", "reviewer"],
  "expected_flow": {
    "do": [
      { "call": "architect", "input": "$query" },
      { "call": "developer", "input": "$architect" },
      { "call": "reviewer", "input": "$developer" }
    ]
  },
  "expected_dph": "@architect(query=$query) -> architect\n$architect.answer -> _architect_text\n@developer(query=$_architect_text) -> developer\n$developer.answer -> _developer_text\n@reviewer(query=$_developer_text) -> reviewer"
}
