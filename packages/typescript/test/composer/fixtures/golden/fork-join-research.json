{
  "id": "fork-join-research",
  "prompt": "Research from two perspectives then synthesize",
  "agents": ["researcher_a", "researcher_b", "synthesizer"],
  "expected_flow": {
    "do": [
      { "parallel": [
          { "call": "researcher_a", "input": "$query" },
          { "call": "researcher_b", "input": "$query" }
      ]},
      { "call": "synthesizer", "input": "$researcher_a + $researcher_b" }
    ]
  },
  "expected_dph": "{\"q\": $query} -> _user_query\n/parallel/\n    @researcher_a(query=$_user_query.q) -> researcher_a\n    @researcher_b(query=$_user_query.q) -> researcher_b\n/end/\n/prompt/\n$researcher_a.answer.answer\n\n$researcher_b.answer.answer\n-> _merged_1\n@synthesizer(query=$_merged_1.answer) -> synthesizer"
}
